      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "topk(10, sum by (container_label_com_docker_swarm_service_name) (rate(container_cpu_usage_seconds_total{container_label_com_docker_swarm_service_name=~\".+\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Top 10 Services by CPU",
      "type": "timeseries"
    },
