# /etc/cron.d/tradingo-docker-cleanup
# Managed by Ansible — do not edit manually
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Remove old Docker images weekly, keeping the 2 most recent per repo
0 3 * * 0  root  /opt/tradingo/cron-scripts/docker-image-cleanup.sh 2>&1 | logger -t docker-image-cleanup
0 3 * * 0  root  docker system prune --volumes -f >&1 | logger -t docker-volume-cleanup
