---
# =============================================================================
# group_vars/all.yml.example — Copy to all.yml and fill in secrets
# cp inventory/group_vars/all.yml.example inventory/group_vars/all.yml
# =============================================================================

# --- Network ---
network_subnet: "192.168.1.0/24"
network_gateway: "192.168.1.1"
dns_servers:
  - "1.1.1.1"
  - "8.8.8.8"
search_domain: "home.lab"

# --- Digital Ocean Gateway ---
do_public_ip: ""               # FILL IN: your droplet's public IP
do_ssh_user: "admin"

# --- WireGuard ---
wg_port: 51820
wg_interface: "wg0"
wg_network: "10.99.0.0/24"
wg_server_ip: "10.99.0.1"      # DO gateway
wg_manager_ip: "10.99.0.2"     # nuc-01

wg_clients:
  rory:
    ip: "10.99.0.10"
  # jane:
  #   ip: "10.99.0.11"

# --- Groups ---
user_groups:
  - name: research
    gid: 1100
  - name: service
    gid: 1200

# --- Users ---
users:
  - username: admin
    uid: 1000
    group: admin
    extra_groups: "sudo,docker"
    shell: /bin/bash
    comment: "Administrator"
    create_home: true
    ssh_key: true
    # Uncomment and set to lock down:
    # password: "{{ vault_admin_password }}"

  - username: rory
    uid: 1100
    group: research
    extra_groups: "sudo,docker,research"
    shell: /bin/bash
    comment: "Rory - Researcher"
    create_home: true
    ssh_key: true
    # password: "{{ vault_rory_password }}"

  - username: service
    uid: 1200
    group: service
    extra_groups: "docker"
    shell: /usr/sbin/nologin
    comment: "Service Account"
    create_home: false
    ssh_key: false

# Users whose authorized_keys we manage
ssh_users:
  - admin
  - rory

# --- NFS ---
nfs_export_base: "/srv/nfs"
nfs_mount_base: "/mnt/nfs"

nfs_shares:
  - name: airflow_dags
    owner_group: research
    mode: "2775"
  - name: airflow_logs
    owner_group: service
    mode: "2775"
  - name: airflow_config
    owner_group: service
    mode: "2775"
  - name: airflow_plugins
    owner_group: service
    mode: "2775"
  - name: tradingo_data
    owner_group: service
    mode: "2775"
  - name: tradingo_backfills
    owner_group: service
    mode: "2775"
  - name: notebooks
    owner_group: research
    mode: "2775"
  - name: scripts
    owner_group: service
    mode: "2775"
  - name: tradingo_src
    owner_group: research
    mode: "2775"
  - name: tradingo_quant_src
    owner_group: research
    mode: "2775"
  - name: research_data
    owner_group: research
    mode: "2775"
  - name: shared
    owner_group: root
    mode: "1777"

# --- Docker ---
docker_daemon_config:
  log-driver: json-file
  log-opts:
    max-size: "20m"
    max-file: "5"
  storage-driver: overlay2
  metrics-addr: "0.0.0.0:9323"
  experimental: true
  default-address-pools:
    - base: "10.10.0.0/16"
      size: 24

